# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_PASSWORD=your-db-password
SUPABASE_PROJECT_ID=your-project-ref
SUPABASE_ACCESS_TOKEN=your-access-token

# PayFast (sandbox during development)
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
NEXT_PUBLIC_PAYFAST_URL=https://sandbox.payfast.co.za

# Peach Payments (Phase 2)
PEACH_API_KEY=
PEACH_ENTITY_ID=

# Resend
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=         # from Resend dashboard → Webhooks → signing secret (whsec_...)
LEGAL_SITE_URL=                # URL of the public marketing site where /terms and /privacy live (prod: https://pleks.co.za; dev: leave unset, falls back to NEXT_PUBLIC_APP_URL)

# Africa's Talking (SMS + WhatsApp)
AT_API_KEY=
AT_USERNAME=
# WhatsApp Business — same AT account, separate phone ID registration
WA_BUSINESS_PHONE_ID=   # Phone number ID from AT WhatsApp Business registration
WA_WEBHOOK_SECRET=      # HMAC secret for verifying AT WhatsApp webhook signatures
# WA_API_KEY=           # Override if WhatsApp uses a different AT API key (usually same as AT_API_KEY)
# WA_USERNAME=          # Override if WhatsApp uses a different AT username (usually same as AT_USERNAME)
# WA_SANDBOX=true       # Set to use AT WhatsApp sandbox endpoint during development

# Anthropic
ANTHROPIC_API_KEY=

# DocuSeal
DOCUSEAL_URL=http://localhost:3001
DOCUSEAL_API_KEY=

# Encryption — AES-256-GCM (POPIA s19)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Use DIFFERENT keys for dev and prod. NEVER commit the real key.
ENCRYPTION_KEY=generate-64-hex-chars-see-above

# Sentry error monitoring (ADDENDUM_00E)
# DSN: https://pleks.sentry.io/settings/projects/pleks/keys/
# Auth token: https://pleks.sentry.io/settings/auth-tokens/ (scopes: project:releases, org:read)
SENTRY_DSN=https://xxx@yyy.ingest.us.sentry.io/zzz
NEXT_PUBLIC_SENTRY_DSN=https://xxx@yyy.ingest.us.sentry.io/zzz
SENTRY_AUTH_TOKEN=sntrys_your_token_here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_MARKETING_URL=http://localhost:3000  # prod: https://pleks.co.za — used for wordmarks + CTAs linking back to marketing site
CRON_SECRET=generate-a-random-string

# Pleks superadmin panel secret — never commit the real value
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=generate-64-hex-chars

# Uptime monitoring (ADDENDUM_00G)
# HEALTH_PROBE_TOKEN: shared secret for /api/health/deep — generate with: openssl rand -hex 32
# Rotate annually; update Better Stack monitor URL after rotation.
HEALTH_PROBE_TOKEN=
# BETTERSTACK_API_KEY: from Better Stack dashboard → Settings → API
BETTERSTACK_API_KEY=
# Heartbeat URLs: copy from each heartbeat monitor in Better Stack. Only set in production.
HEARTBEAT_DAILY=
HEARTBEAT_ARREARS_SEQUENCE=
HEARTBEAT_INVOICE_GENERATE=
HEARTBEAT_BILLING_CASCADE=
HEARTBEAT_COST_SNAPSHOTS=
# Optional: Vercel + Supabase management API tokens (ADDENDUM_00H Tier 2 — auto-pull of monthly spend)
# VERCEL_API_TOKEN=
# VERCEL_TEAM_ID=
# SUPABASE_MANAGEMENT_TOKEN=
# SUPABASE_PROJECT_REF=

# Searchworx (ADDENDUM_14A / 14H — property intelligence + applicant screening)
# Docs: https://doccentral.searchworks.co.za
# UAT base URL: https://uatrest.searchworks.co.za (dev default — set SEARCHWORX_BASE_URL to override)
# Production base URL: https://rest.searchworks.co.za (confirm with Searchworx before go-live)
SEARCHWORX_USERNAME=
SEARCHWORX_PASSWORD=
SEARCHWORX_BASE_URL=https://uatrest.searchworks.co.za

# Internal API secret (ADDENDUM_14A — webhook → vendor execution fire-and-forget auth)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_SECRET=

# Consent verification (ADDENDUM_14F)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CONSENT_HMAC_SECRET=

# Passkey → session-AAL2 signal (ADDENDUM_69 Slice A). Signs the pleks_aal cookie so a
# verified passkey grants AAL2 without TOTP. MUST be >=32 chars and server-only. If UNSET,
# the feature is disabled (fail-closed): passkey login falls back to the TOTP step.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PASSKEY_AAL_SECRET=
