{
  "name": "pleks",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=4096 next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit && eslint . --max-warnings 0 && node scripts/check-legal-localhost.mjs && node scripts/check-marketing-consistency.mjs && node scripts/architecture-audit.mjs && node scripts/schema-contract-scan.mjs && node scripts/check-audit-columns.mjs && node scripts/check-file-headers.mjs && tsx scripts/security/check-pii-classification.mts && vitest run",
    "check:full": "npm run check && npm run security:db && node scripts/check-drift-if-sql-changed.mjs",
    "security:db": "node scripts/security/audit.mjs --ci && tsx scripts/security/cat14-behavioural.mts --ci && tsx scripts/security/trust-sovereignty-parity.mts --ci",
    "security:behavioural": "tsx scripts/security/cat14-behavioural.mts",
    "security:prod": "cross-env APP_URL=https://app.pleks.co.za node scripts/security/audit.mjs",
    "security:prod:quick": "cross-env APP_URL=https://app.pleks.co.za node scripts/security/audit.mjs --quick",
    "test": "vitest run",
    "test:watch": "vitest",
    "nuke-user": "node scripts/nuke-user.mjs",
    "fitscore:replay": "node scripts/fitscore-replay.mjs",
    "render:fitscore-e1": "cross-env FITSCORE_FONT_SOURCE=local tsx scripts/render-e1-chrome-test.ts",
    "render:fitscore-samples": "cross-env FITSCORE_FONT_SOURCE=local tsx scripts/render-fitscore-samples.ts",
    "fitscore:render-smoke": "cross-env FITSCORE_FONT_SOURCE=local tsx scripts/render-fitscore-smoke.ts",
    "render:density-pass": "cross-env FITSCORE_FONT_SOURCE=local tsx scripts/render-density-pass.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@base-ui/react": "^1.6.0",
    "@fullcalendar/daygrid": "^6.1.21",
    "@fullcalendar/interaction": "^6.1.21",
    "@fullcalendar/list": "^6.1.21",
    "@fullcalendar/react": "^6.1.21",
    "@fullcalendar/timegrid": "^6.1.21",
    "@hookform/resolvers": "^5.4.0",
    "@react-email/components": "^1.0.12",
    "@react-pdf/renderer": "^4.5.1",
    "@sentry/nextjs": "^10.63.0",
    "@serwist/next": "^9.5.11",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.2",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.0",
    "@tanstack/react-query": "^5.101.2",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "docx": "^9.7.1",
    "heic2any": "^0.0.4",
    "libphonenumber-js": "^1.13.8",
    "lucide-react": "^1.23.0",
    "next": "^16.2.10",
    "next-nprogress-bar": "^2.4.7",
    "papaparse": "^5.5.4",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "qrcode": "^1.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-email": "^6.6.6",
    "react-hook-form": "^7.81.0",
    "recharts": "^3.9.2",
    "resend": "^6.17.1",
    "serwist": "^9.5.7",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "svix": "^1.96.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "overrides": {
    "fast-uri": "3.1.2",
    "esbuild": "0.28.1",
    "hono": "4.12.25",
    "ws": "8.21.0"
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22.20.0",
    "@types/papaparse": "^5.5.2",
    "@types/pdf-parse": "^1.1.5",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.6.0",
    "eslint-config-next": "^16.2.9",
    "eslint-plugin-sonarjs": "^4.1.0",
    "exceljs": "^4.4.0",
    "semantic-release": "^25.0.5",
    "tailwindcss": "^4",
    "ts-morph": "^28.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
